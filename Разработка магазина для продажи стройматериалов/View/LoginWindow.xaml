<Window x:Class="Magaz_Stroitelya.View.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Magaz_Stroitelya.View"
        mc:Ignorable="d"
        Title="LoginWindow" Height="400" Width="500" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="200">
            <TextBlock Text="Логин" FontSize="16"/>
            <TextBox Text="{Binding Login}" Margin="0,10" FontSize="16"/>
            <TextBlock Text="Пароль" FontSize="16"/>
            <TextBox Text="{Binding Password}" Margin="0,10" FontSize="16"/>
            <TextBlock Text="{Binding Error}" FontSize="13" TextAlignment="Center" Foreground="Red"/>
            <TextBlock Text="Регистрация" FontSize="13" TextAlignment="Center" Foreground="Blue" TextDecorations="Underline">
                <TextBlock.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding RegisterCommand}"/>
                </TextBlock.InputBindings>
            </TextBlock>
            <Button Content="Вход" Command="{Binding LoginCommand}" Margin="0,10" FontSize="16"/>
        </StackPanel>
    </Grid>
</Window>
