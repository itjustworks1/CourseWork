<Window x:Class="MVVM.View.NoAdmin.WindowListOrders"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:MVVM.ViewModel.NoAdmin"
        xmlns:view="clr-namespace:MVVM.View.NoAdmin"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="Список заказов" Height="450" Width="400" WindowStartupLocation="CenterScreen">
    <Grid>
        <ListBox ItemsSource="{Binding OrdersWithoutCart}" SelectedItem="{Binding SelectedOrder}" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Border BorderThickness="1" BorderBrush="Black">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="260"/>
                                    <ColumnDefinition Width="0"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Date}" VerticalAlignment="Center" FontSize="20">
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftDoubleClick"
          Command="{Binding DataContext.OpenOrder, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"/>
                                    </TextBlock.InputBindings>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <Button Width="60" Content="Редактировать" 
            Command="{Binding DataContext.EditOrder2Command, RelativeSource={RelativeSource AncestorType={x:Type view:WindowListOrders}}}" 
            CommandParameter="{Binding .}" Margin="10,0,0,0" Grid.Column="2">
                            <!--<i:Interaction.Triggers>
            <i:EventTrigger EventName="Click">
                <i:InvokeCommandAction  />
                -->
                            <!--<i:InvokeCommandAction Command="{Binding DataContext.EditOrder, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />-->
                            <!--
            </i:EventTrigger>
        </i:Interaction.Triggers>-->
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
