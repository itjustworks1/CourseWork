<Window x:Class="MVVM.View.NoAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MVVM"
        xmlns:view="clr-namespace:MVVM.View.NoAdmin"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="Магазин стройматериалов" Height="450" Width="800" x:Name="qwe1" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid Margin="10">
            <TextBox Name="tb1" MinWidth="400" MaxWidth="500" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Margin="10,0" FontSize="20"/>
            <TextBlock 
                   Text="Поиск"
                   IsHitTestVisible="False"
                   FontSize="20"
                   MaxWidth="{Binding ActualWidth, ElementName=tb1}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsKeyboardFocused, ElementName=tb1}"
                                           Value="False"/>
                                    <Condition Binding="{Binding Text, ElementName=tb1}"
                                           Value="{x:Static sys:String.Empty}"
                                           xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="1" Grid.ColumnSpan="2">
            <Button Width="100" Content="Корзина" Command="{Binding OpenCart}" Margin="30,0" FontSize="16"/>
        </StackPanel>
        <Grid Grid.Row="2" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Button Content="Применить" Command="{Binding ApplyFilters}" Margin="10,0"/>
                <ListBox ItemsSource="{Binding Filters}" Margin="10" Grid.Row="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Text.Title}" FontSize="16"/>
                                <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Bottom" Margin="10,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <!-- Запрещает фокус, что делает выбор невозможным -->
                            <Setter Property="Focusable" Value="False" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
            <ListBox Name="LBox" ItemsSource="{Binding SearchProducts}" SelectedItem="{Binding SelectedProduct}" Margin="10" Grid.Column="1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Border BorderThickness="1" BorderBrush="Black">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="240"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="20">
                                            <TextBlock.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.OpenProduct, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"/>
                                            </TextBlock.InputBindings>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="1">
                                            <TextBlock Text="{Binding Value}" FontSize="20">
                                                <TextBlock.InputBindings>
                                                    <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.OpenProduct, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"/>
                                                </TextBlock.InputBindings>
                                            </TextBlock>
                                            <TextBlock Text="р" FontSize="20"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Grid.Column="2">
                                            <TextBlock Text="{Binding Quantity}" FontSize="16">
                                                <TextBlock.InputBindings>
                                                    <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.OpenProduct, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"/>
                                                </TextBlock.InputBindings>
                                            </TextBlock>
                                            <TextBlock Text="шт"  FontSize="16"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Button Width="60" Margin="10,0,0,0" Grid.Column="2"
                                Command="{Binding DataContext.AddToCart2Command, RelativeSource={RelativeSource AncestorType={x:Type view:MainWindow}}}" 
                                CommandParameter="{Binding .}" >
                                    <!--<i:Interaction.Triggers>
                                        <i:EventTrigger EventName="Click">
                                            <i:InvokeCommandAction Command="{Binding AddToCart}" />
                                            <i:InvokeCommandAction Command="{Binding DataContext.AddToCart, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>-->
                                    <TextBlock> Добавить <LineBreak/> в корзину</TextBlock>
                                </Button>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</Window>
